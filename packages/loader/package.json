{
  "name": "@agentfare/loader",
  "version": "0.2.1",
  "description": "Module loader for injecting AgentFare hooks at runtime",
  "license": "MIT",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist"
  ],
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/MjxUpUp/AgentFare.git",
    "directory": "packages/loader"
  },
  "scripts": {
    "build": "tsc",
    "test": "vitest run",
    "test:watch": "vitest",
    "prepublishOnly": "node ../../scripts/prepublish-check.js"
  },
  "dependencies": {
    "@agentfare/hook": "workspace:*",
    "@agentfare/models": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "typescript": "^5.8",
    "vitest": "^3.2"
  }
}
