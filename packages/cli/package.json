{
  "name": "@agentfare/cli",
  "version": "0.1.20",
  "description": "Command-line interface for AgentFare cost optimization",
  "license": "MIT",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist"
  ],
  "bin": {
    "agentfare": "dist/index.js"
  },
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/MjxUpUp/AgentFare.git",
