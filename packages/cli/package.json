  },
  "scripts": {
    "build": "tsc",
    "test": "vitest run",
    "test:watch": "vitest",
    "preinstall": "node dist/preinstall-stop-proxy.js || exit 0"
  },
  "dependencies": {
    "@agentfare/core": "workspace:*",
    "@agentfare/hook": "workspace:*",
    "@agentfare/loader": "workspace:*",
    "@agentfare/models": "workspace:*",
    "@agentfare/proxy": "workspace:*",
    "@agentfare/setup": "workspace:*",
    "commander": "^13.0.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "typescript": "^5.8",
    "vitest": "^3.2"
  }
}
