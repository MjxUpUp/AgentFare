{
  "name": "@agentfare/hook",
  "version": "0.1.5",
  "description": "Fetch interception hooks with protocol conversion for AgentFare",
  "license": "MIT",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist"
  ],
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/MjxUpUp/AgentFare.git",
    "directory": "packages/hook"
  },
  "exports": {
    ".": "./dist/index.js",
    "./fetch-patch": "./dist/fetch-patch.js",
    "./request-handler": "./dist/request-handler.js",
    "./response-handler": "./dist/response-handler.js",
    "./headers": "./dist/headers.js",
    "./reentry-guard": "./dist/reentry-guard.js",
    "./protocol/openai-to-anthropic": "./dist/protocol/openai-to-anthropic.js",
    "./protocol/anthropic-to-openai-request": "./dist/protocol/anthropic-to-openai-request.js",
    "./protocol/anthropic-to-openai": "./dist/protocol/anthropic-to-openai.js",
    "./protocol/openai-to-anthropic-response": "./dist/protocol/openai-to-anthropic-response.js",
    "./protocol/openai-to-anthropic-sse": "./dist/protocol/openai-to-anthropic-sse.js",
    "./protocol/sse-transform": "./dist/protocol/sse-transform.js"
  },
  "scripts": {
    "build": "tsc",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@agentfare/core": "^0.1.3",
    "@agentfare/models": "^0.1.3"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "typescript": "^5.8",
    "vitest": "^3.2"
  }
}
