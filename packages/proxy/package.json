{
  "name": "@agentfare/proxy",
  "version": "0.2.0",
  "description": "HTTP proxy server with provider routing and SSE streaming for AgentFare",
  "license": "MIT",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist"
  ],
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/MjxUpUp/AgentFare.git",
    "directory": "packages/proxy"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./server": {
      "types": "./dist/server.d.ts",
      "default": "./dist/server.js"
    },
    "./lifecycle": {
      "types": "./dist/lifecycle.d.ts",
      "default": "./dist/lifecycle.js"
    },
    "./provider-map": {
      "types": "./dist/provider-map.d.ts",
      "default": "./dist/provider-map.js"
    },
    "./key-store": {
      "types": "./dist/key-store.d.ts",
      "default": "./dist/key-store.js"
    },
    "./sse-pipe": {
      "types": "./dist/sse-pipe.d.ts",
      "default": "./dist/sse-pipe.js"
    },
    "./tool-guide": {
      "types": "./dist/tool-guide.d.ts",
      "default": "./dist/tool-guide.js"
    },
    "./daemon-entry": {
      "types": "./dist/daemon-entry.d.ts",
      "default": "./dist/daemon-entry.js"
    }
  },
  "scripts": {
    "build": "tsc",
    "test": "vitest run",
    "test:watch": "vitest",
    "prepublishOnly": "node ../../scripts/prepublish-check.js"
  },
  "dependencies": {
    "@agentfare/core": "workspace:*",
    "@agentfare/hook": "workspace:*",
    "@agentfare/models": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "typescript": "^5.8",
    "vitest": "^3.2"
  }
}
